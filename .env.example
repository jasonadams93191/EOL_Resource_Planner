# ============================================================
# AA / EOL Capacity Planner — Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

NODE_ENV=development

# EOL Tech Team Jira Workspace
JIRA_EOL_BASE_URL=https://your-org.atlassian.net
JIRA_EOL_EMAIL=your-email@example.com
JIRA_EOL_API_TOKEN=your-jira-api-token-here
JIRA_EOL_PROJECT_KEY=EOL

# AA/TKO Projects Jira Workspace (project key: ATI)
JIRA_ATI_BASE_URL=https://your-org.atlassian.net
JIRA_ATI_EMAIL=your-email@example.com
JIRA_ATI_API_TOKEN=your-jira-api-token-here
JIRA_ATI_PROJECT_KEY=ATI

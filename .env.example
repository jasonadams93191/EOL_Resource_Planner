# ============================================================
# AA / EOL Capacity Planner — Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

NODE_ENV=development

# EOL Tech Team Jira Workspace
JIRA_EOL_BASE_URL=https://your-org.atlassian.net
JIRA_EOL_EMAIL=your-email@example.com
JIRA_EOL_API_TOKEN=your-jira-api-token-here
JIRA_EOL_PROJECT_KEY=EOL

# AA/TKO Projects Jira Workspace (project key: ATI)
JIRA_ATI_BASE_URL=https://your-org.atlassian.net
JIRA_ATI_EMAIL=your-email@example.com
JIRA_ATI_API_TOKEN=your-jira-api-token-here
JIRA_ATI_PROJECT_KEY=ATI

# Shared Jira instance (Layout A — takes precedence over per-workspace vars above)
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-jira-api-token-here
# JIRA_PROJECT_KEYS=EOL,ATI

# Anthropic — LLM enrichment (gaps only, rules layer runs first)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# Feature flags (safe defaults shown)
LLM_ENABLE=true
LLM_MAX_INITIATIVES_PER_RUN=20
LLM_MAX_CHARS_PER_INITIATIVE=20000
JIRA_WRITE_ENABLED=false
DATA_MODE_DEFAULT=seed
